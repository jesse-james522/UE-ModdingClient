<UserControl x:Class="OrionLauncher.Views.ModsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Border Padding="28,24">
            <StackPanel MaxWidth="560" HorizontalAlignment="Left" VerticalAlignment="Top">

                <!-- ── Server dock ──────────────────────────────────────────── -->
                <Border Background="#0E1520" BorderBrush="#1E3050" BorderThickness="1"
                        CornerRadius="6" Padding="18,14" Margin="0,0,0,28">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Online indicator dot -->
                        <Ellipse Grid.Row="0" Grid.Column="0"
                                 Width="10" Height="10"
                                 VerticalAlignment="Center"
                                 Margin="0,0,10,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#444"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ServerVm.IsOnline}" Value="True">
                                            <Setter Property="Fill" Value="#4FC84F"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>

                        <!-- Server address -->
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding ServerVm.ServerName}"
                                   FontSize="15" FontWeight="SemiBold" Foreground="#DDD"
                                   VerticalAlignment="Center"/>

                        <!-- Refresh button -->
                        <Button Grid.Row="0" Grid.Column="3"
                                Content="↻"
                                Command="{Binding ServerVm.RefreshCommand}"
                                IsEnabled="{Binding ServerVm.IsLoading, Converter={StaticResource InverseBool}}"
                                Style="{StaticResource ActionButtonStyle}"
                                Padding="8,4" FontSize="14"
                                ToolTip="Refresh server status"/>

                        <!-- Status line -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"
                                   Text="{Binding ServerVm.StatusLine}"
                                   Foreground="#556" FontSize="11"
                                   Margin="0,6,0,0"/>
                    </Grid>
                </Border>

                <!-- ── Mod info ──────────────────────────────────────────────── -->

                <!-- Mod title -->
                <TextBlock Text="{Binding ModName}"
                           FontSize="22" FontWeight="Bold" Foreground="#EEE"
                           Margin="0,0,0,4"/>

                <!-- Author -->
                <TextBlock Text="{Binding ModAuthor}"
                           Foreground="#888" FontSize="13"
                           Margin="0,0,0,14"/>

                <!-- Description -->
                <TextBlock Text="{Binding ModDescription}"
                           TextWrapping="Wrap" Foreground="#BBB" FontSize="13"
                           Margin="0,0,0,24"/>

                <!-- Status row: badge + force re-download -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">

                    <!-- Up to date badge -->
                    <Border Background="#152515" BorderBrush="#2A5A2A" BorderThickness="1"
                            CornerRadius="4" Padding="12,7"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsUpToDate, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="✓  Up to date" Foreground="#6CF06C" FontSize="12" FontWeight="SemiBold"/>
                    </Border>

                    <!-- Update available badge -->
                    <Border Background="#252510" BorderBrush="#5A5010" BorderThickness="1"
                            CornerRadius="4" Padding="12,7"
                            VerticalAlignment="Center"
                            Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="↑  Update available" Foreground="#E8C040" FontSize="12" FontWeight="SemiBold"/>
                    </Border>

                    <!-- Force re-download -->
                    <Button Content="⟳  Re-download"
                            Command="{Binding ForceRedownloadCommand}"
                            IsEnabled="{Binding IsDownloading, Converter={StaticResource InverseBool}}"
                            Margin="10,0,0,0" Padding="12,6"
                            Style="{StaticResource ActionButtonStyle}"
                            ToolTip="Force a fresh download regardless of current version"/>
                </StackPanel>

                <!-- Download progress bar -->
                <ProgressBar Value="{Binding DownloadProgressPct}"
                             Maximum="100" Height="6"
                             Margin="0,10,0,4"
                             Background="#222" BorderBrush="#444"
                             Foreground="#0078D4"
                             Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibility}}"/>

                <!-- Commit info / download status -->
                <TextBlock Text="{Binding CommitInfo}"
                           Foreground="#555" FontSize="11" Margin="0,4,0,0"/>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>
