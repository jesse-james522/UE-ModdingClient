<UserControl x:Class="OrionLauncher.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16" MaxWidth="620">

            <!-- Game Directory -->
            <TextBlock Text="GAME DIRECTORY" Style="{StaticResource SectionHeaderStyle}"/>
            <Grid Margin="0,4,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding GameDirectory, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InputStyle}" Margin="0,0,4,0"/>
                <Button Grid.Column="1" Content="Browse..."
                        Command="{Binding BrowseCommand}"
                        Padding="10,4" Style="{StaticResource ActionButtonStyle}"/>
            </Grid>
            <TextBlock Text="{Binding DetectedPath, StringFormat='Auto-detected: {0}'}"
                       Foreground="#555" FontSize="11" Margin="0,0,0,14"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,28">
                <Button Content="Save Settings" Command="{Binding SaveCommand}"
                        Padding="14,6" Style="{StaticResource PrimaryButtonStyle}"/>
            </StackPanel>

            <!-- Separator -->
            <Border BorderBrush="#333" BorderThickness="0,1,0,0" Margin="0,0,0,16"/>

            <!-- Developer -->
            <TextBlock Text="DEVELOPER" Style="{StaticResource SectionHeaderStyle}"/>
            <Border BorderBrush="#333" BorderThickness="1" CornerRadius="4" Padding="14" Margin="0,6,0,28">
                <StackPanel>
                    <TextBlock Foreground="#666" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12"
                               Text="Override the server IP fetched from GitHub. Leave blank to use the published IP.txt. Hit Save Settings above after changing."/>
                    <TextBlock Text="Custom Server IP" Foreground="#888" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding DevServerIp, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource InputStyle}"
                             Width="260" HorizontalAlignment="Left"
                             ToolTip="Direct IP:port — overrides the IP.txt fetched from GitHub"
                             x:Name="DevIpBox"/>
                </StackPanel>
            </Border>

            <!-- Separator -->
            <Border BorderBrush="#333" BorderThickness="0,1,0,0" Margin="0,0,0,16"/>

            <!-- Danger Zone -->
            <TextBlock Text="DANGER ZONE" Style="{StaticResource SectionHeaderStyle}"/>
            <Border BorderBrush="#5A2020" BorderThickness="1" CornerRadius="4" Padding="14" Margin="0,6,0,0">
                <StackPanel>
                    <TextBlock Foreground="#AA7070" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,14"
                               Text="These operations modify files in your game installation and cannot be undone."/>

                    <!-- Restore Game -->
                    <StackPanel Margin="0,0,0,12">
                        <Button Content="Restore Game to Vanilla"
                                Command="{Binding RestoreGameCommand}"
                                HorizontalAlignment="Left" Padding="14,8"
                                Style="{StaticResource DangerButtonStyle}"/>
                        <TextBlock Foreground="#666" FontSize="11" Margin="0,4,0,0"
                                   Text="Removes EAC bypass, bypass shims, and all mod files from the game folder."/>
                    </StackPanel>

                    <!-- Clear mod cache -->
                    <StackPanel>
                        <Button Content="Clear Downloaded Mods"
                                Command="{Binding ClearDownloadedModsCommand}"
                                HorizontalAlignment="Left" Padding="14,8"
                                Style="{StaticResource DangerButtonStyle}"/>
                        <TextBlock Foreground="#666" FontSize="11" Margin="0,4,0,0"
                                   Text="Deletes cached mod files — they will re-download on the next inject."/>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
